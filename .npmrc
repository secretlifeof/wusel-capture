# Enforce pnpm
engine-strict=true

# Use workspace protocol for workspace dependencies
link-workspace-packages=true

# Hoist pattern for better compatibility
shamefully-hoist=false

# Store location (optional - defaults to ~/.pnpm-store)
# store-dir=.pnpm-store

# Auto install peers
auto-install-peers=true

# Strict peer dependencies
strict-peer-dependencies=false

# Enable node-linker for better compatibility with some tools
# node-linker=hoisted
