{
  "name": "@wusel-capture/host",
  "version": "0.1.0",
  "private": true,
  "description": "Native messaging host for Wusel Capture: writes a browser capture into the URL-mapped project folder and opens Claude Code in VS Code.",
  "type": "module",
  "bin": {
    "wusel-capture-host": "./dist/index.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "install-host": "node scripts/install.mjs",
    "type-check": "oxlint --type-aware --type-check --ignore-pattern='*.test.*'"
  },
  "devDependencies": {
    "@wusel-capture/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.0"
  }
}
